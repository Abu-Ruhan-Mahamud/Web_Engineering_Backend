# ============================================================================
# CUROVA PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# IMPORTANT: Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git!
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Must be a strong, random string (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-very-long-random-secret-key-here-min-50-characters

# MUST BE FALSE IN PRODUCTION
DEBUG=False

# Your production domain (Railway provides one like: curova-app.railway.app)
ALLOWED_HOSTS=curova-app.railway.app,www.curova-app.railway.app

# ============================================================================
# DATABASE (Railway auto-injects DATABASE_URL, but you can use these too)
# ============================================================================

# OPTION 1: Use DATABASE_URL (Railway provides this automatically)
# Uncomment and set if using Railway or similar
# DATABASE_URL=postgresql://user:password@host:5432/curova_db

# OPTION 2: Use individual database settings (if DATABASE_URL not available)
DB_NAME=curova_db
DB_USER=curova_user
DB_PASSWORD=your-secure-db-password-here
DB_HOST=your-database-host.railway.internal
DB_PORT=5432

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Your production frontend domain(s) - comma separated
CORS_ALLOWED_ORIGINS=https://curova-app.railway.app,https://www.curova-app.railway.app

# ============================================================================
# GOOGLE OAUTH (Optional - add later if needed)
# ============================================================================

GOOGLE_CLIENT_ID=your-google-client-id-here

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================

# For Railway:
# 1. Create account at railway.app (use GitHub Student Pack credits)
# 2. Create new project → PostgreSQL database
# 3. Create Django service pointing to this repo:
#    - Set build command: pip install -r requirements.txt
#    - Set start command: python backend/manage.py migrate --noinput && gunicorn curova_backend.wsgi
#    - Add environment variables from this file
# 4. Connect database to Django service
# 5. Deploy!

# For DigitalOcean:
# 1. Use $100 credit from GitHub Student Pack
# 2. Create PostgreSQL database
# 3. Deploy with Docker (see Dockerfile)
# 4. Set environment variables in app settings

# ============================================================================
# SECURITY GUIDELINES
# ============================================================================

# - SECRET_KEY: Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# - DB_PASSWORD: Use strong password, at least 16 characters
# - ALLOWED_HOSTS: Only include domains where app will actually run
# - CORS_ALLOWED_ORIGINS: Only include frontend domain(s)
# - Never logging SECRET_KEY or DB_PASSWORD
# - Enable HTTPS in production (Railway does this automatically)

